# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-manager-secret-value
DJANGO_ALLOWED_HOSTS=ostrov.quest,www.ostrov.quest
DJANGO_CSRF_TRUSTED_ORIGINS=https://ostrov.quest,https://www.ostrov.quest
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Cloud Run / Gunicorn
PORT=8080
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info

# Database
# Use either DATABASE_URL or the explicit POSTGRES_* + CLOUD_SQL_CONNECTION_NAME settings.
# Recommended for Cloud SQL Unix socket:
# DATABASE_URL=
POSTGRES_DB=ostrov_quest
POSTGRES_USER=ostrov_quest
POSTGRES_PASSWORD=replace-with-secret-manager-secret-value
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONN_HEALTH_CHECKS=True
CLOUD_SQL_CONNECTION_NAME=project-id:region:instance-name

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_STATIC_BUCKET_NAME=ostrov-quest-static
GCS_MEDIA_BUCKET_NAME=ostrov-quest-media
GCS_STATIC_PREFIX=static
GCS_MEDIA_PREFIX=media
GCS_QUERYSTRING_AUTH=False
GCS_MEDIA_QUERYSTRING_AUTH=False
GCS_STATIC_CACHE_CONTROL=public, max-age=31536000, immutable
GCS_MEDIA_CACHE_CONTROL=public, max-age=3600
# Optional explicit CDN / custom asset URLs:
# DJANGO_STATIC_URL=https://storage.googleapis.com/ostrov-quest-static/static/
# DJANGO_MEDIA_URL=https://storage.googleapis.com/ostrov-quest-media/media/

# Optional bootstrap admin job
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ostrov.quest
DJANGO_SUPERUSER_PASSWORD=replace-with-secret-manager-secret-value
